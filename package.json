{
  "name": "@yusufolosun/bitflow-lend-sdk",
  "version": "1.0.1",
  "description": "Professional TypeScript SDK for BitFlow Lend - Bitcoin-native lending on Stacks blockchain",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "stacks",
    "cryptocurrency",
    "crypto",
    "bitcoin",
    "lending",
    "defi",
    "blockchain",
    "bitflow",
    "clarity",
    "web3",
    "btc",
    "stx"
  ],
  "author": "BitFlow Lend",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Yusufolosun/bitflow-lend-sdk.git"
  },
  "bugs": {
    "url": "https://github.com/Yusufolosun/bitflow-lend-sdk/issues"
  },
  "homepage": "https://github.com/Yusufolosun/bitflow-lend-sdk#readme",
  "funding": {
    "type": "github",
    "url": "https://github.com/Yusufolosun"
  },
  "peerDependencies": {
    "@stacks/network": "^7.3.0",
    "@stacks/transactions": "^7.3.0"
  },
  "devDependencies": {
    "@stacks/network": "^7.3.1",
    "@stacks/transactions": "^7.3.1",
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "eslint": "^8.56.0",
    "tsup": "^8.0.1",
    "typescript": "^5.3.3",
    "vitest": "^1.2.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
